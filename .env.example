# Frontend: which entry to run
# demo = midterm demo
# product = final product shell
VITE_APP_MODE=demo

# Frontend: base path for API requests
VITE_API_BASE=/api

# Backend: local server port
PORT=3001

# Backend: which frontend origin can access the API in local development
CORS_ORIGIN=http://localhost:5173

# AI access layer
# For your current plan, the provider is PackyCode
AI_PROVIDER=packycode

# Third-party AI service endpoint and credentials
AI_BASE_URL=
AI_API_KEY=

# Model selection for experiments / A-B tests
AI_MODEL=
AI_MODEL_FAMILY=
